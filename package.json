{
  "name": "agent-arbitrage-platform",
  "version": "1.0.0",
  "description": "Find undervalued AI agents across chains - reputation vs price arbitrage",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npx esbuild src/main.jsx --bundle --outfile=dist/assets/main.js --servedir=. --serve=3000",
    "dev:server": "node server/index.js",
    "build": "node build.js",
    "preview": "npx serve dist",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.90.0",
    "@vitejs/plugin-react": "^4.2.0",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "ethers": "^6.11.0",
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "esbuild": "^0.27.3"
  }
}
